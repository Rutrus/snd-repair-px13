--- a/sound/soc/codecs/tas2783-sdw.c
+++ b/sound/soc/codecs/tas2783-sdw.c
@@ -912,6 +912,18 @@
 	if (!sdw_stream)
 		return -EINVAL;
 
+	/*
+	 * Speaker-only DisCo exposes sink_ports (playback) but no source_ports.
+	 * Do not join the capture SDW stream or sdw_program_port_params()
+	 * will fail with -EINVAL on a non-existent DPN.
+	 */
+	if (substream->stream == SNDRV_PCM_STREAM_CAPTURE &&
+	    !sdw_peripheral->prop.source_ports) {
+		dev_dbg(tas_dev->dev,
+			"no source_ports, skipping capture hw_params\n");
+		return 0;
+	}
+
 	ret = tas_clear_latch(tas_dev);
 	if (ret)
 		dev_err(tas_dev->dev,
@@ -963,6 +975,10 @@
 	struct sdw_stream_runtime *sdw_stream =
 		snd_soc_dai_get_dma_data(dai, substream);
 
+	if (substream->stream == SNDRV_PCM_STREAM_CAPTURE &&
+	    !tas_dev->sdw_peripheral->prop.source_ports)
+		return 0;
+
 	sdw_stream_remove_slave(tas_dev->sdw_peripheral, sdw_stream);
 
 	mutex_lock(&tas_dev->pde_lock);
