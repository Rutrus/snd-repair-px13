From: snd-repair <snd-repair@local>
Date: Mon, 14 Jul 2026 16:00:00 +0200
Subject: [PATCH] ASoC: tas2783: repeat fw reinit on first hw_params after system sleep

After system suspend/resume, tas2783_fw_reinit() invoked from the SoundWire
resume / update_status(ATTACHED) path completes without error but leaves the
SmartAmp playback path non-functional on some platforms (e.g. dual-TAS2783
SoundWire laptops). A second fw_reinit() at the first real playback hw_params
— when clocks, DAPM, and stream ports are prepared — restores stereo output.

Validated on ASUS ProArt PX13 (kernel 7.0): identical register readback in
pass vs fail states; the same fw_reinit() succeeds when deferred to stream
setup. Event-driven hook at first hw_params (0 ms artificial delay) restores
stereo L+R.

Arm resume_playback_reinit_pending after the resume-path fw_reinit(); run
one additional fw_reinit() on the first hw_params only, then clear the flag.
Clear the flag on system suspend and UNATTACHED.

Signed-off-by: snd-repair <snd-repair@local>
---
 sound/soc/codecs/tas2783-sdw.c | 45 ++++++++++++++++++++++++++++++++++--
 1 file changed, 43 insertions(+), 2 deletions(-)

diff --git a/sound/soc/codecs/tas2783-sdw.c b/sound/soc/codecs/tas2783-sdw.c
--- a/sound/soc/codecs/tas2783-sdw.c
+++ b/sound/soc/codecs/tas2783-sdw.c
@@ -101,6 +101,8 @@ struct tas2783_prv {
 	wait_queue_head_t fw_wait;
 	bool fw_dl_task_done;
 	bool fw_dl_success;
+	bool post_system_sleep;
+	bool resume_playback_reinit_pending;
 };
 
 static s32 tas_io_init(struct device *dev, struct sdw_slave *slave);
@@ -108,6 +110,22 @@ static s32 tas2783_fw_reinit(struct device *dev, struct sdw_slave *slave);
 static int tas2783_sdca_dev_system_suspend(struct device *dev);
 static int tas2783_sdca_dev_system_resume(struct device *dev);
 
+static s32 tas2783_post_sleep_resume_fw_reinit(struct device *dev,
+					       struct sdw_slave *slave)
+{
+	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
+	s32 ret;
+
+	if (!tas_dev)
+		return -ENODEV;
+
+	tas_dev->post_system_sleep = false;
+	ret = tas2783_fw_reinit(dev, slave);
+	if (!ret)
+		tas_dev->resume_playback_reinit_pending = true;
+
+	return ret;
+}
+
 static int tas2783_sdca_dev_runtime_suspend(struct device *dev)
 {
 	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
@@ -903,6 +921,18 @@ static s32 tas_sdw_hw_params(struct snd_pcm_substream *substream,
 	struct sdw_slave *sdw_peripheral = tas_dev->sdw_peripheral;
 	s32 ret, retry = 3;
 
+	if (tas_dev->resume_playback_reinit_pending &&
+	    tas_dev->status == SDW_SLAVE_ATTACHED) {
+		tas_dev->resume_playback_reinit_pending = false;
+		ret = tas2783_fw_reinit(&sdw_peripheral->dev, sdw_peripheral);
+		if (ret) {
+			dev_warn(tas_dev->dev,
+				 "post-sleep playback fw_reinit failed: %d\n",
+				 ret);
+			return ret;
+		}
+	}
+
 	if (!tas_dev->fw_dl_success && !tas_dev->fw_dl_task_done &&
 	    tas_dev->status == SDW_SLAVE_ATTACHED) {
 		ret = tas2783_fw_reinit(&sdw_peripheral->dev, sdw_peripheral);
@@ -1109,8 +1139,9 @@ static s32 tas2783_sdca_dev_system_suspend(struct device *dev)
 {
 	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
 
-	if (tas_dev && tas_dev->hw_init) {
+	if (tas_dev) {
 		tas_dev->post_system_sleep = true;
+		tas_dev->resume_playback_reinit_pending = false;
 		tas_dev->hw_init = false;
 		tas_dev->fw_dl_task_done = false;
 		tas_dev->fw_dl_success = false;
@@ -1142,6 +1173,10 @@ regmap_sync:
 	regcache_cache_only(tas_dev->regmap, false);
 	regcache_sync(tas_dev->regmap);
 
+	if (tas_dev->post_system_sleep &&
+	    tas_dev->status == SDW_SLAVE_ATTACHED)
+		return tas2783_post_sleep_resume_fw_reinit(dev, slave);
+
 	if (tas_dev->status == SDW_SLAVE_ATTACHED && !tas_dev->hw_init)
 		ret = tas2783_fw_reinit(dev, slave);
 	return ret;
@@ -1254,8 +1289,16 @@ static s32 tas_update_status(struct sdw_slave *slave,
 	struct tas2783_prv *tas_dev = dev_get_drvdata(&slave->dev);
 	s32 ret;
 
-	if (status == SDW_SLAVE_UNATTACHED)
+	if (status == SDW_SLAVE_UNATTACHED) {
 		tas_dev->hw_init = false;
+		tas_dev->resume_playback_reinit_pending = false;
+	}
+
+	if (status == SDW_SLAVE_ATTACHED && tas_dev->post_system_sleep) {
+		regcache_cache_only(tas_dev->regmap, false);
+		regcache_sync(tas_dev->regmap);
+		return tas2783_post_sleep_resume_fw_reinit(&slave->dev, slave);
+	}
 
 	if (status == SDW_SLAVE_ATTACHED && tas_dev->hw_init &&
 	    (!tas_dev->fw_dl_success || !tas_dev->fw_dl_task_done))
