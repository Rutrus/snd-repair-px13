# Kernel source tree (scripts/prepare-kernel-tree.sh)
linux-source-*/
build/

# Kernel source packages
linux-source-*.deb

# Build artifacts
*.ko
*.ko.zst
*.o
*.cmd
Module.symvers
modules.order
.tmp_versions/
*.snd-repair-*

# Local module backups
*.ko.zst.orig

# ---------------------------------------------------------------------------
# Reproducible validation outputs — regenerate with hunt/sweep scripts.
# See validation/README.md and scripts/phase6-hunt.sh
# ---------------------------------------------------------------------------
validation/.state/
validation/boot-logs/*.log
validation/phase6-runs/hunt-*/
validation/phase6-runs/run-*/

# Aggregated CSVs (append-only hunt logs; reproducible from runs)
validation/phase6-hunt-log.csv
validation/phase6-chronology.csv
validation/phase6-events.csv
validation/phase6-kmsg-events.csv
validation/resume-matrix.csv
validation/fw-matrix.csv
validation/fw-summary.md

# Post-S2 / capture witness run outputs (regenerable; see scripts/post-s2-*.sh)
validation/post-s2-user-witness/
validation/post-s2-witness/
validation/post-s2-kernel-witness/
validation/capture-probe-*/
validation/capture-access-matrix*/
validation/capture-client-matrix*/
validation/pw-vs-alsa-diff-*/
validation/sdwcap-lifecycle-post-s2-*/
validation/post-s2-persistence-kpi-u-*.log
validation/post-s2-persistence-kpi-u-*.csv
validation/post-s2-persistence-kpi-u-*.result

# ACPI debug dumps (large, regenerable)
research/acpi_debug/
research/snapshots/*
!research/snapshots/.gitkeep

# Upstream test apply trees
upstream/_test/
upstream/_test-apply/

# Proprietary firmware — never commit
firmware/
*.bin

# Temp / logs
/tmp/
*.log
*~

# Editor / OS
.DS_Store
*.swp
.cursor/
