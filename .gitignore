# Árbol de fuentes del kernel (descargar con scripts/prepare-kernel-tree.sh)
linux-source-*/
build/

# Paquetes .deb de fuentes
linux-source-*.deb

# Artefactos de compilación
*.ko
*.ko.zst
*.o
*.cmd
Module.symvers
modules.order
