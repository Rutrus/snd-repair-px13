From: snd-repair phase6 <snd-repair@local>
Date: Fri, 10 Jul 2026 14:10:00 +0200
Subject: [PATCH phase6 7/7] soundwire: amd: resume kick sequence trace (0007)

Applies on 0006. Existence probes for each software step that should
lead to the first hardware IRQ — not more register dumps.

Probes: clk_resume_done/skip, clear_slave_status, init_sdw_manager,
enable_sdw_manager, frameshape_done, device_state_D0, intr_stat_post_D0.

Signed-off-by: snd-repair phase6 <snd-repair@local>
---
--- a/drivers/soundwire/amd_manager.c
+++ b/drivers/soundwire/amd_manager.c
@@ -1487,12 +1487,26 @@ static int __maybe_unused amd_resume_runtime(struct device *dev)
 			if (val & AMD_SDW_CLK_RESUME_DONE) {
 				writel(0, amd_manager->mmio + ACP_SW_CLK_RESUME_CTRL);
 				amd_manager->clk_stopped = false;
+				dev_info(dev,
+					 "PHASE6 ctx=amd fn=clk_resume_done link=%d resume=%d\n",
+					 bus->link_id, amd_phase6_resume_id(amd_manager));
 			}
+		} else {
+			dev_info(dev,
+				 "PHASE6 ctx=amd fn=clk_resume_skip link=%d resume=%d\n",
+				 bus->link_id, amd_phase6_resume_id(amd_manager));
 		}
 		amd_phase6_mark_reset(amd_manager);
 		dev_info(dev, "PHASE6 ctx=amd fn=manager_reset link=%d resume=%d t=+0ms\n",
 			 bus->link_id, amd_phase6_resume_id(amd_manager));
 		sdw_clear_slave_status(bus, SDW_UNATTACH_REQUEST_MASTER_RESET);
-		amd_init_sdw_manager(amd_manager);
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=clear_slave_status link=%d resume=%d\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager));
+		ret = amd_init_sdw_manager(amd_manager);
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=init_sdw_manager link=%d resume=%d ret=%d\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager), ret);
 		amd_enable_sdw_interrupts(amd_manager);
 		dev_info(dev, "PHASE6 ctx=amd fn=irq_enabled link=%d resume=%d\n",
 			 bus->link_id, amd_phase6_resume_id(amd_manager));
@@ -1508,10 +1522,16 @@ static int __maybe_unused amd_resume_runtime(struct device *dev)
 			 readl(amd_manager->acp_mmio +
 			       ACP_EXTERNAL_INTR_STAT(amd_manager->instance)));
 		ret = amd_enable_sdw_manager(amd_manager);
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=enable_sdw_manager link=%d resume=%d ret=%d\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager), ret);
 		if (ret)
 			return ret;
 		dev_info(dev,
 			 "PHASE6 ctx=amd fn=sdw_en_post_resume link=%d resume=%d val=0x%x\n",
 			 bus->link_id, amd_phase6_resume_id(amd_manager),
 			 readl(amd_manager->mmio + ACP_SW_EN_STATUS));
 		amd_sdw_set_frameshape(amd_manager);
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=frameshape_done link=%d resume=%d\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager));
 		dev_info(dev,
 			 "PHASE6 ctx=amd fn=clk_frame link=%d resume=%d val=0x%x\n",
 			 bus->link_id, amd_phase6_resume_id(amd_manager),
@@ -1526,6 +1546,14 @@ static int __maybe_unused amd_resume_runtime(struct device *dev)
 	}
 	if (amd_manager->acp_rev >= ACP70_PCI_REV_ID) {
 		ret = amd_sdw_set_device_state(amd_manager, AMD_SDW_DEVICE_STATE_D0);
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=device_state_D0 link=%d resume=%d ret=%d val=0x%x\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager), ret,
+			 readl(amd_manager->acp_mmio + AMD_SDW_DEVICE_STATE));
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=intr_stat_post_D0 link=%d resume=%d stat=0x%x\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager),
+			 readl(amd_manager->acp_mmio +
+			       ACP_EXTERNAL_INTR_STAT(amd_manager->instance)));
 		if (ret)
 			return ret;
 	}
