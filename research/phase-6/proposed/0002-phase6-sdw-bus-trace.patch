 #include <linux/mod_devicetable.h>
 #include <linux/pm_runtime.h>
 #include <linux/soundwire/sdw_registers.h>
@@ -15,6 +16,77 @@
 
 static DEFINE_IDA(sdw_bus_ida);
 
+#define SDW_PHASE6_TS_SLOTS (SDW_MAX_DEVICES + 1)
+static ktime_t sdw_phase6_reinit_ts[SDW_PHASE6_TS_SLOTS];
+static const char *sdw_phase6_detach_reason = "unknown";
+
+static void sdw_phase6_set_detach_reason(const char *reason)
+{
+	sdw_phase6_detach_reason = reason;
+}
+
+static const char *sdw_phase6_status_name(enum sdw_slave_status status)
+{
+	switch (status) {
+	case SDW_SLAVE_UNATTACHED:
+		return "UNATTACHED";
+	case SDW_SLAVE_ATTACHED:
+		return "ATTACHED";
+	case SDW_SLAVE_ALERT:
+		return "ALERT";
+	default:
+		return "OTHER";
+	}
+}
+
+static void sdw_phase6_state_change(struct sdw_slave *slave,
+				    enum sdw_slave_status old,
+				    enum sdw_slave_status new)
+{
+	struct sdw_bus *bus = slave->bus;
+	int dn = slave->dev_num;
+
+	if (old == new)
+		return;
+
+	dev_info(&slave->dev,
+		 "PHASE6 ctx=sdw fn=state_change master=%d link=%d dev=%d uid=0x%x old=%s new=%s reason=%s\n",
+		 bus->controller_id, bus->link_id, dn, slave->id.unique_id,
+		 sdw_phase6_status_name(old), sdw_phase6_status_name(new),
+		 new == SDW_SLAVE_UNATTACHED ? sdw_phase6_detach_reason : "-");
+
+	if (new == SDW_SLAVE_UNATTACHED && dn > 0 && dn < SDW_PHASE6_TS_SLOTS)
+		sdw_phase6_reinit_ts[dn] = ktime_get_boottime();
+	else if (old == SDW_SLAVE_UNATTACHED && new == SDW_SLAVE_ATTACHED &&
+		 dn > 0 && dn < SDW_PHASE6_TS_SLOTS &&
+		 !ktime_to_ns(sdw_phase6_reinit_ts[dn]))
+		sdw_phase6_reinit_ts[dn] = ktime_get_boottime();
+}
+
+static void sdw_phase6_completion(struct sdw_slave *slave)
+{
+	struct sdw_bus *bus = slave->bus;
+	int dn = slave->dev_num;
+	s64 elapsed_ms = -1;
+	const char *phase = "resume";
+
+	if (dn > 0 && dn < SDW_PHASE6_TS_SLOTS &&
+	    ktime_to_ns(sdw_phase6_reinit_ts[dn]))
+		elapsed_ms = ktime_to_ms(ktime_sub(ktime_get_boottime(),
+						   sdw_phase6_reinit_ts[dn]));
+	else
+		phase = "boot";
+
+	dev_info(&slave->dev,
+		 "PHASE6 ctx=sdw fn=completion master=%d link=%d dev=%d uid=0x%x elapsed_ms=%lld phase=%s\n",
+		 bus->controller_id, bus->link_id, dn, slave->id.unique_id,
+		 (long long)elapsed_ms, phase);
+}
+
+static void sdw_phase6_state_skip(struct sdw_slave *slave, const char *reason)
+{
+	struct sdw_bus *bus = slave->bus;
+
+	dev_info(&slave->dev,
+		 "PHASE6 ctx=sdw fn=state_skip master=%d link=%d dev=%d uid=0x%x reason=%s sw=%s\n",
+		 bus->controller_id, bus->link_id, slave->dev_num,
+		 slave->id.unique_id, reason, sdw_phase6_status_name(slave->status));
+}
+
+
 static int sdw_get_id(struct sdw_bus *bus)
 {
 	int rc = ida_alloc(&sdw_bus_ida, GFP_KERNEL);
