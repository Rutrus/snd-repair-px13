From: snd-repair phase6 <snd-repair@local>
Date: Fri, 10 Jul 2026 03:10:00 +0200
Subject: [PATCH phase6 4/4] soundwire: amd: minimal IRQ chain trace (0004)

Applies on top of 0003. Four existence probes post manager_reset:
resume_enter (0003), irq_enabled, ping_irq, queue_work (minimal).
Optional ACP pci-ps sdw0_irq when hardware IRQ reaches handler.

Signed-off-by: snd-repair phase6 <snd-repair@local>
---
--- a/drivers/soundwire/amd_manager.c
+++ b/drivers/soundwire/amd_manager.c
@@ -1036,6 +1036,11 @@ static void amd_sdw_irq_thread(struct work_struct *work)
 
 	status_change_8to11 = readl(amd_manager->mmio + ACP_SW_STATE_CHANGE_STATUS_8TO11);
 	status_change_0to7 = readl(amd_manager->mmio + ACP_SW_STATE_CHANGE_STATUS_0TO7);
+	dev_info(amd_manager->dev,
+		 "PHASE6 ctx=amd fn=ping_irq link=%d resume=%d t=+%lldms sc_0to7=0x%x sc_8to11=0x%x\n",
+		 amd_manager->instance, amd_phase6_resume_id(amd_manager),
+		 (long long)amd_phase6_since_reset_ms(amd_manager),
+		 status_change_0to7, status_change_8to11);
 	if (!status_change_0to7 && !status_change_8to11)
 		return;
 
@@ -1053,11 +1058,9 @@ static void amd_sdw_irq_thread(struct work_struct *work)
 		amd_sdw_update_slave_status(status_change_0to7, status_change_8to11, amd_manager);
 	}
 	if (status_change_8to11 || status_change_0to7) {
 		dev_info(amd_manager->dev,
-			 "PHASE6 ctx=amd fn=queue_work link=%d resume=%d t=+%lldms devmask=0x%x sc_0to7=0x%x sc_8to11=0x%x\n",
+			 "PHASE6 ctx=amd fn=queue_work link=%d resume=%d t=+%lldms\n",
 			 amd_manager->instance, amd_phase6_resume_id(amd_manager),
-			 (long long)amd_phase6_since_reset_ms(amd_manager),
-			 amd_phase6_attached_mask(amd_manager),
-			 status_change_0to7, status_change_8to11);
+			 (long long)amd_phase6_since_reset_ms(amd_manager));
 		schedule_work(&amd_manager->amd_sdw_work);
 	}
 	writel(0x00, amd_manager->mmio + ACP_SW_STATE_CHANGE_STATUS_8TO11);
@@ -1487,6 +1490,9 @@ static int __maybe_unused amd_resume_runtime(struct device *dev)
 			 bus->link_id, amd_phase6_resume_id(amd_manager));
 		sdw_clear_slave_status(bus, SDW_UNATTACH_REQUEST_MASTER_RESET);
 		amd_init_sdw_manager(amd_manager);
 		amd_enable_sdw_interrupts(amd_manager);
+		dev_info(dev, "PHASE6 ctx=amd fn=irq_enabled link=%d resume=%d\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager));
 		ret = amd_enable_sdw_manager(amd_manager);
 		if (ret)
 			return ret;
--- a/sound/soc/amd/ps/pci-ps.c
+++ b/sound/soc/amd/ps/pci-ps.c
@@ -208,6 +208,8 @@ static irqreturn_t acp_irq_handler(int irq, void *dev_id)
 	 */
 	ext_intr_stat = readl(adata->acp63_base + ACP_EXTERNAL_INTR_STAT);
 	if (ext_intr_stat & ACP_SDW0_STAT) {
+		dev_info(&adata->pci->dev,
+			 "PHASE6 ctx=acp fn=sdw0_irq link=0 stat=0x%x\n", ext_intr_stat);
 		writel(ACP_SDW0_STAT, adata->acp63_base + ACP_EXTERNAL_INTR_STAT);
 		amd_manager = dev_get_drvdata(&adata->sdw->pdev[0]->dev);
 		if (amd_manager)
