From: snd-repair phase6 <snd-repair@local>
Date: Fri, 10 Jul 2026 02:55:00 +0200
Subject: [PATCH phase6 3/3] soundwire: amd: PHASE6 resume trace + resume_id

Observation-only: resume_enter, manager_reset, ping_status, queue_work,
handle_status — each with resume=N (0=runtime PM), t=+ms since reset.

Signed-off-by: snd-repair phase6 <snd-repair@local>
---
--- a/drivers/soundwire/amd_manager.c	2026-04-12 22:48:06.000000000 +0200
+++ b/drivers/soundwire/amd_manager.c	2026-07-10 02:34:23.612789479 +0200
@@ -6,11 +6,13 @@
  */
 
 #include <linux/completion.h>
+#include <linux/atomic.h>
 #include <linux/cleanup.h>
 #include <linux/device.h>
 #include <linux/io.h>
 #include <linux/jiffies.h>
 #include <linux/kernel.h>
+#include <linux/ktime.h>
 #include <linux/module.h>
 #include <linux/slab.h>
 #include <linux/soundwire/sdw.h>
@@ -23,6 +25,65 @@
 #include "amd_init.h"
 #include "amd_manager.h"
 
+static atomic_t amd_phase6_system_sleep;
+static atomic_t amd_phase6_resume_seq;
+#define AMD_PHASE6_MAX_LINKS 2
+static ktime_t amd_phase6_reset_ts[AMD_PHASE6_MAX_LINKS];
+static int amd_phase6_link_resume_id[AMD_PHASE6_MAX_LINKS];
+
+static int amd_phase6_resume_id(struct amd_sdw_manager *amd_manager)
+{
+	int li = amd_manager->instance;
+
+	if (li >= 0 && li < AMD_PHASE6_MAX_LINKS)
+		return amd_phase6_link_resume_id[li];
+	return 0;
+}
+
+static s64 amd_phase6_since_reset_ms(struct amd_sdw_manager *amd_manager)
+{
+	int li = amd_manager->instance;
+
+	if (li < 0 || li >= AMD_PHASE6_MAX_LINKS ||
+	    !ktime_to_ns(amd_phase6_reset_ts[li]))
+		return -1;
+	return ktime_to_ms(ktime_sub(ktime_get_boottime(), amd_phase6_reset_ts[li]));
+}
+
+static void amd_phase6_mark_reset(struct amd_sdw_manager *amd_manager)
+{
+	int li = amd_manager->instance;
+
+	if (li >= 0 && li < AMD_PHASE6_MAX_LINKS)
+		amd_phase6_reset_ts[li] = ktime_get_boottime();
+}
+
+static const char *amd_phase6_status_name(enum sdw_slave_status status)
+{
+	switch (status) {
+	case SDW_SLAVE_UNATTACHED:
+		return "UNATTACHED";
+	case SDW_SLAVE_ATTACHED:
+		return "ATTACHED";
+	case SDW_SLAVE_ALERT:
+		return "ALERT";
+	default:
+		return "OTHER";
+	}
+}
+
+static u32 amd_phase6_attached_mask(struct amd_sdw_manager *amd_manager)
+{
+	u32 mask = 0;
+	int i;
+
+	for (i = 1; i <= SDW_MAX_DEVICES; i++) {
+		if (amd_manager->status[i] == SDW_SLAVE_ATTACHED)
+			mask |= BIT(i);
+	}
+	return mask;
+}
+
 #define DRV_NAME "amd_sdw_manager"
 
 #define to_amd_sdw(b)	container_of(b, struct amd_sdw_manager, bus)
@@ -418,6 +479,10 @@
 	mutex_lock(&amd_manager->bus.msg_lock);
 	response = amd_sdw_send_cmd_get_resp(amd_manager, 0, 0);
 	mutex_unlock(&amd_manager->bus.msg_lock);
+	dev_info(amd_manager->dev,
+		 "PHASE6 ctx=amd fn=ping_status link=%d resume=%d t=+%lldms resp=0x%llx\n",
+		 amd_manager->instance, amd_phase6_resume_id(amd_manager),
+		 (long long)amd_phase6_since_reset_ms(amd_manager), response);
 	amd_sdw_process_ping_status(response, amd_manager);
 }
 
@@ -483,6 +548,10 @@
 	struct amd_sdw_manager *amd_manager = to_amd_sdw(bus);
 	u32 frame_fmt_reg, dpn_frame_fmt;
 
+	dev_err(amd_manager->dev,
+		"ENZODBG[5] amd_port ENTER link=%d port=%d bps=%d flow=%d data=%d\n",
+		bus->link_id, p_params->num, p_params->bps,
+		p_params->flow_mode, p_params->data_mode);
 	dev_dbg(amd_manager->dev, "p_params->num:0x%x\n", p_params->num);
 	switch (amd_manager->acp_rev) {
 	case ACP63_PCI_REV_ID:
@@ -494,6 +563,9 @@
 			frame_fmt_reg = acp63_sdw1_dp_reg[p_params->num].frame_fmt_reg;
 			break;
 		default:
+			dev_err(amd_manager->dev,
+				"ENZODBG[5] amd_port FAIL link=%d ret=-EINVAL bad instance\n",
+				bus->link_id);
 			return -EINVAL;
 		}
 		break;
@@ -503,6 +575,9 @@
 		frame_fmt_reg = acp70_sdw_dp_reg[p_params->num].frame_fmt_reg;
 		break;
 	default:
+		dev_err(amd_manager->dev,
+			"ENZODBG[5] amd_port FAIL link=%d ret=-EINVAL bad acp_rev=0x%x\n",
+			bus->link_id, amd_manager->acp_rev);
 		return -EINVAL;
 	}
 
@@ -511,6 +586,9 @@
 	u32p_replace_bits(&dpn_frame_fmt, p_params->data_mode, AMD_DPN_FRAME_FMT_PDM);
 	u32p_replace_bits(&dpn_frame_fmt, p_params->bps - 1, AMD_DPN_FRAME_FMT_WORD_LEN);
 	writel(dpn_frame_fmt, amd_manager->mmio + frame_fmt_reg);
+	dev_err(amd_manager->dev,
+		"ENZODBG[5] amd_port OK link=%d port=%d ret=0\n",
+		bus->link_id, p_params->num);
 	return 0;
 }
 
@@ -519,6 +597,14 @@
 				    enum sdw_reg_bank bank)
 {
 	struct amd_sdw_manager *amd_manager = to_amd_sdw(bus);
+
+	dev_err(amd_manager->dev,
+		"ENZODBG[4] amd_xport ENTER link=%d rev=0x%x port=%d bank=%d "
+		"hstart=%d hstop=%d lane=%d off1=%d off2=%d samp=%d\n",
+		bus->link_id, amd_manager->acp_rev, params->port_num, bank,
+		params->hstart, params->hstop, params->lane_ctrl,
