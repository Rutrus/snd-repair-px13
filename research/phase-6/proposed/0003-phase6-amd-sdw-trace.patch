 	u32 dpn_sampleinterval;
 	u32 dpn_hctrl;
@@ -547,6 +633,9 @@
 					acp63_sdw1_dp_reg[params->port_num].lane_ctrl_ch_en_reg;
 			break;
 		default:
+			dev_err(amd_manager->dev,
+				"ENZODBG[4] amd_xport FAIL link=%d ret=-EINVAL instance=%d\n",
+				bus->link_id, amd_manager->instance);
 			return -EINVAL;
 		}
 		break;
@@ -560,6 +649,9 @@
 		lane_ctrl_ch_en_reg = acp70_sdw_dp_reg[params->port_num].lane_ctrl_ch_en_reg;
 		break;
 	default:
+		dev_err(amd_manager->dev,
+			"ENZODBG[4] amd_xport FAIL link=%d ret=-EINVAL acp_rev=0x%x\n",
+			bus->link_id, amd_manager->acp_rev);
 		return -EINVAL;
 	}
 	writel(AMD_SDW_SSP_COUNTER_VAL, amd_manager->mmio + ACP_SW_SSP_COUNTER);
@@ -588,6 +680,11 @@
 	dpn_lanectrl = readl(amd_manager->mmio + lane_ctrl_ch_en_reg);
 	u32p_replace_bits(&dpn_lanectrl, params->lane_ctrl, AMD_DPN_CH_EN_LCTRL);
 	writel(dpn_lanectrl, amd_manager->mmio + lane_ctrl_ch_en_reg);
+
+	dev_err(amd_manager->dev,
+		"ENZODBG[4] amd_xport OK link=%d port=%d hstart=%d hstop=%d lane=%d ret=0\n",
+		bus->link_id, params->port_num, params->hstart, params->hstop,
+		params->lane_ctrl);
 	return 0;
 }
 
@@ -868,6 +965,14 @@
 	}
 
 update_status:
+	dev_info(amd_manager->dev,
+		 "PHASE6 ctx=amd fn=handle_status link=%d resume=%d t=+%lldms st0=%s st1=%s st2=%s st3=%s retry=%d\n",
+		 amd_manager->instance, amd_phase6_resume_id(amd_manager),
+		 (long long)amd_phase6_since_reset_ms(amd_manager),
+		 amd_phase6_status_name(amd_manager->status[0]),
+		 amd_phase6_status_name(amd_manager->status[1]),
+		 amd_phase6_status_name(amd_manager->status[2]),
+		 amd_phase6_status_name(amd_manager->status[3]), retry_count);
 	sdw_handle_slave_status(&amd_manager->bus, amd_manager->status);
 	/*
 	 * During the peripheral enumeration sequence, the SoundWire manager interrupts
@@ -947,8 +1052,15 @@
 		/* Check for the updated status on peripheral device */
 		amd_sdw_update_slave_status(status_change_0to7, status_change_8to11, amd_manager);
 	}
-	if (status_change_8to11 || status_change_0to7)
+	if (status_change_8to11 || status_change_0to7) {
+		dev_info(amd_manager->dev,
+			 "PHASE6 ctx=amd fn=queue_work link=%d resume=%d t=+%lldms devmask=0x%x sc_0to7=0x%x sc_8to11=0x%x\n",
+			 amd_manager->instance, amd_phase6_resume_id(amd_manager),
+			 (long long)amd_phase6_since_reset_ms(amd_manager),
+			 amd_phase6_attached_mask(amd_manager),
+			 status_change_0to7, status_change_8to11);
 		schedule_work(&amd_manager->amd_sdw_work);
+	}
 	writel(0x00, amd_manager->mmio + ACP_SW_STATE_CHANGE_STATUS_8TO11);
 	writel(0x00, amd_manager->mmio + ACP_SW_STATE_CHANGE_STATUS_0TO7);
 }
@@ -1209,6 +1321,7 @@
 	struct sdw_bus *bus = &amd_manager->bus;
 	int ret;
 
+	atomic_set(&amd_phase6_system_sleep, 1);
 	if (bus->prop.hw_disabled) {
 		dev_dbg(bus->dev, "SoundWire manager %d is disabled, ignoring\n",
 			bus->link_id);
@@ -1318,6 +1431,29 @@
 		return 0;
 	}
 
+	{
+		bool system = atomic_xchg(&amd_phase6_system_sleep, 0) != 0;
+		int rid = 0;
+
+		if (system) {
+			rid = atomic_inc_return(&amd_phase6_resume_seq);
+			if (amd_manager->instance >= 0 &&
+			    amd_manager->instance < AMD_PHASE6_MAX_LINKS)
+				amd_phase6_link_resume_id[amd_manager->instance] = rid;
+		} else if (amd_manager->instance >= 0 &&
+			   amd_manager->instance < AMD_PHASE6_MAX_LINKS) {
+			amd_phase6_link_resume_id[amd_manager->instance] = 0;
+		}
+
+		dev_info(dev,
+			 "PHASE6 ctx=amd fn=resume_enter link=%d resume=%d pm=%s mode=%s\n",
+			 bus->link_id, rid,
+			 system ? "system_resume" : "runtime_resume",
+			 (amd_manager->power_mode_mask & AMD_SDW_CLK_STOP_MODE) ? "clk_stop" :
+			 (amd_manager->power_mode_mask & AMD_SDW_POWER_OFF_MODE) ? "power_off" :
+			 "other");
+	}
+
 	if (amd_manager->power_mode_mask & AMD_SDW_CLK_STOP_MODE) {
 		ret = amd_sdw_clock_stop_exit(amd_manager);
 		if (ret)
@@ -1346,6 +1482,9 @@
 				amd_manager->clk_stopped = false;
 			}
 		}
+		amd_phase6_mark_reset(amd_manager);
+		dev_info(dev, "PHASE6 ctx=amd fn=manager_reset link=%d resume=%d t=+0ms\n",
+			 bus->link_id, amd_phase6_resume_id(amd_manager));
 		sdw_clear_slave_status(bus, SDW_UNATTACH_REQUEST_MASTER_RESET);
 		amd_init_sdw_manager(amd_manager);
 		amd_enable_sdw_interrupts(amd_manager);
