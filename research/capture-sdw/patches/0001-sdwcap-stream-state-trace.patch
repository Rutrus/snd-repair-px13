+/* SDWCAP — trace every stream->state transition (snd_repair capture P0) */
+static const char *sdwcap_state_name(enum sdw_stream_state st)
+{
+	switch (st) {
+	case SDW_STREAM_ALLOCATED:
+		return "ALLOCATED";
+	case SDW_STREAM_CONFIGURED:
+		return "CONFIGURED";
+	case SDW_STREAM_PREPARED:
+		return "PREPARED";
+	case SDW_STREAM_ENABLED:
+		return "ENABLED";
+	case SDW_STREAM_DISABLED:
+		return "DISABLED";
+	case SDW_STREAM_DEPREPARED:
+		return "DEPREPARED";
+	case SDW_STREAM_RELEASED:
+		return "RELEASED";
+	default:
+		return "?";
+	}
+}
+
+static const char *sdwcap_stream_dir(const struct sdw_stream_runtime *stream)
+{
+	if (!stream || !stream->name)
+		return "?";
+	if (strstr(stream->name, "Capture"))
+		return "capture";
+	if (strstr(stream->name, "Playback"))
+		return "playback";
+	return "?";
+}
+
+static void sdwcap_log_stream_ctx(const struct sdw_stream_runtime *stream, const char *tag)
+{
+	struct sdw_master_runtime *m_rt;
+	struct sdw_slave_runtime *s_rt;
+	struct sdw_port_runtime *p_rt;
+	bool any = false;
+
+	if (!stream)
+		return;
+
+	list_for_each_entry(m_rt, &stream->master_list, stream_node) {
+		list_for_each_entry(s_rt, &m_rt->slave_rt_list, m_rt_node) {
+			if (!s_rt->slave)
+				continue;
+			list_for_each_entry(p_rt, &s_rt->port_list, port_node) {
+				any = true;
+				pr_info("SDWCAP ctx tag=%s stream=%p name=%s dir=%s slave=%s uid=0x%x status=%u sdir=%d port=%d mdir=%d\n",
+					tag, stream,
+					stream->name ? stream->name : "?",
+					sdwcap_stream_dir(stream),
+					dev_name(&s_rt->slave->dev),
+					s_rt->slave->id.unique_id,
+					s_rt->slave->status,
+					s_rt->direction, p_rt->num,
+					m_rt->direction);
+			}
+		}
+	}
+	if (!any)
+		pr_info("SDWCAP ctx tag=%s stream=%p name=%s dir=%s (no slave/port yet)\n",
+			tag, stream,
+			stream->name ? stream->name : "?",
+			sdwcap_stream_dir(stream));
+}
+
+static void sdwcap_stream_set_state(struct sdw_stream_runtime *stream,
+				    enum sdw_stream_state new_state,
+				    void *caller)
+{
+	enum sdw_stream_state old_state;
+
+	if (!stream)
+		return;
+
+	old_state = stream->state;
+	if (old_state == new_state)
+		return;
+
+	stream->state = new_state;
+
+	pr_info("SDWCAP trans stream=%p name=%s dir=%s old=%u:%s new=%u:%s caller=%pS\n",
+		stream, stream->name ? stream->name : "?",
+		sdwcap_stream_dir(stream),
+		old_state, sdwcap_state_name(old_state),
+		new_state, sdwcap_state_name(new_state), caller);
+
+	if (old_state >= SDW_STREAM_CONFIGURED &&
+	    new_state == SDW_STREAM_ALLOCATED)
+		dump_stack();
+}
+
