 	struct tas2783_prv *tas_dev =
 		(struct tas2783_prv *)context;
 	const u8 *buf = NULL;
+	u8 uid = tas2783_w4_uid(tas_dev);
+
+	tas2783_w4_life(tas_dev->dev, uid, "fw_ready", "enter");
 	s32  img_sz, ret = 0, cur_file = 0;
 	s32 offset = 0;
 
@@ -787,6 +887,11 @@
 						       file->dest_addr,
 						       file->length,
 						       file->fw_data);
+				if (w4_sdca_trace)
+					dev_info(tas_dev->dev,
+						 "W4 ctx=sdca fn=nwrite uid=%d addr=0x%x len=%d try=%d ret=%d file=%d\n",
+						 uid, file->dest_addr, file->length,
+						 attempt, ret, cur_file);
 				if (ret >= 0)
 					break;
 				if (ret != -ETIMEDOUT && ret != -EAGAIN)
@@ -811,10 +916,15 @@
 		tas2783_update_calibdata(tas_dev);
 	}
 
+	tas2783_w4_life(tas_dev->dev, uid, "fw_ready",
+			ret ? "exit_err" : "exit_ok");
+
 out:
 	if (!ret)
 		tas_dev->fw_dl_success = true;
 	tas_dev->fw_dl_task_done = true;
+	tas2783_w4_life(tas_dev->dev, uid, "fw_ready", "done_flags");
+	tas2783_w4_readback(tas_dev->dev, tas_dev, "fw_ready_out");
 	wake_up(&tas_dev->fw_wait);
 	if (fmw)
 		release_firmware(fmw);
@@ -834,6 +944,8 @@
 	struct tas2783_prv *tas_dev = snd_soc_component_get_drvdata(component);
 	s32 mute;
 
+	tas2783_w4_life(tas_dev->dev, tas2783_w4_uid(tas_dev),
+			"fu21_event", event == SND_SOC_DAPM_POST_PMU ? "post_pmu" : "pre_pmd");
 	switch (event) {
 	case SND_SOC_DAPM_POST_PMU:
 		mute = 0;
@@ -844,7 +956,7 @@
 		break;
 	}
 
-	return sdw_write_no_pm(tas_dev->sdw_peripheral,
+	return tas2783_w4_sdw_write(tas_dev,
 			       SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_FU21,
 					    TAS2783_SDCA_CTL_FU_MUTE, 1), mute);
 }
@@ -856,6 +968,8 @@
 	struct tas2783_prv *tas_dev = snd_soc_component_get_drvdata(component);
 	s32 mute;
 
+	tas2783_w4_life(tas_dev->dev, tas2783_w4_uid(tas_dev),
+			"fu23_event", event == SND_SOC_DAPM_POST_PMU ? "post_pmu" : "pre_pmd");
 	switch (event) {
 	case SND_SOC_DAPM_POST_PMU:
 		mute = 0;
@@ -866,7 +980,7 @@
 		break;
 	}
 
-	return sdw_write_no_pm(tas_dev->sdw_peripheral,
+	return tas2783_w4_sdw_write(tas_dev,
 			       SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_FU23,
 					    TAS2783_SDCA_CTL_FU_MUTE, 1), mute);
 }
@@ -920,6 +1034,9 @@
 	struct sdw_stream_runtime *sdw_stream;
 	struct sdw_slave *sdw_peripheral = tas_dev->sdw_peripheral;
 	s32 ret, retry = 3;
+	u8 uid = tas2783_w4_uid(tas_dev);
+
+	tas2783_w4_life(tas_dev->dev, uid, "hw_params", "enter");
 
 	if (!tas_dev->fw_dl_success && !tas_dev->fw_dl_task_done &&
 	    tas_dev->status == SDW_SLAVE_ATTACHED) {
@@ -969,7 +1086,7 @@
 	 * port prepare succeeds
 	 */
 	do {
-		ret = regmap_write(tas_dev->regmap,
+		ret = tas2783_w4_regmap_write(tas_dev,
 				   SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_PDE23,
 						TAS2783_SDCA_CTL_REQ_POW_STATE, 0),
 						TAS2783_SDCA_POW_STATE_ON);
@@ -1010,6 +1127,9 @@
 	if (ret)
 		dev_err(dai->dev, "Unable to configure port\n");
 
+	tas2783_w4_life(tas_dev->dev, uid, "hw_params", ret ? "exit_err" : "exit_ok");
+	tas2783_w4_readback(tas_dev->dev, tas_dev, "hw_params_out");
+
 	return ret;
 }
 
@@ -1141,6 +1261,9 @@
 {
 	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
 
+	if (tas_dev)
+		tas2783_w4_life(dev, tas2783_w4_uid(tas_dev),
+				"system_suspend", "enter");
 	if (tas_dev) {
 		tas_dev->post_system_sleep = true;
 		tas_dev->hw_init = false;
@@ -1157,6 +1280,9 @@
 	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
 	s32 ret = 0;
 	unsigned long t;
+	u8 uid = tas_dev ? tas2783_w4_uid(tas_dev) : 0;
+
+	tas2783_w4_life(dev, uid, "resume", "enter");
 
 	if (!slave->unattach_request)
 		goto regmap_sync;
@@ -1177,6 +1303,7 @@
 
 	if (tas_dev->post_system_sleep &&
 	    tas_dev->status == SDW_SLAVE_ATTACHED) {
+		tas2783_w4_life(dev, uid, "resume", "force_fw_reinit");
 		dev_info(dev,
 			 "W2 ctx=tas fn=force_fw_reinit when=resume uid=%d\n",
 			 tas_dev->sdw_peripheral->id.unique_id);
@@ -1184,8 +1311,12 @@
 		return tas2783_fw_reinit(dev, slave);
 	}
 
-	if (tas_dev->status == SDW_SLAVE_ATTACHED && !tas_dev->hw_init)
+	if (tas_dev->status == SDW_SLAVE_ATTACHED && !tas_dev->hw_init) {
+		tas2783_w4_life(dev, uid, "resume", "fw_reinit_hw_init_false");
 		ret = tas2783_fw_reinit(dev, slave);
+	}
+
+	tas2783_w4_life(dev, uid, "resume", ret ? "exit_err" : "exit_ok");
 	return ret;
 }
 
@@ -1225,13 +1356,16 @@
 	s32 ret;
 	u8 unique_id = tas_dev->sdw_peripheral->id.unique_id;
 
+	tas2783_w4_life(dev, unique_id, "io_init", "enter");
+
 	if (tas_dev->hw_init)
 		return 0;
 
 	tas_dev->fw_dl_task_done = false;
