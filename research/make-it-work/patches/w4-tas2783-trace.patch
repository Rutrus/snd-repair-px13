From: snd-repair make-it-work <snd-repair@local>
Date: Mon, 13 Jul 2026 11:35:00 +0200
Subject: [PATCH w4] ASoC: tas2783: W4 lifecycle + SDCA trace (diagnostic)

Diagnostic only — applies on upstream series B + W2.

Signed-off-by: snd-repair make-it-work <snd-repair@local>
---
--- a/sound/soc/codecs/tas2783-sdw.c
+++ b/sound/soc/codecs/tas2783-sdw.c
@@ -15,6 +15,7 @@
 #include <linux/unaligned.h>
 #include <linux/crc32.h>
 #include <linux/efi.h>
+#include <linux/atomic.h>
 #include <linux/err.h>
 #include <linux/firmware.h>
 #include <linux/init.h>
@@ -40,6 +41,22 @@
 #include "tas2783.h"
 
 #define TIMEOUT_FW_DL_MS (3000)
+
+/* W4 diagnostic — compare ordered init sequence: cold boot vs post-S2 */
+static bool w4_lifecycle_trace = true;
+module_param(w4_lifecycle_trace, bool, 0644);
+MODULE_PARM_DESC(w4_lifecycle_trace,
+		 "Log ordered W4 lifecycle steps (seq=N) for PASS vs FAIL diff");
+
+static bool w4_sdca_trace;
+module_param(w4_sdca_trace, bool, 0644);
+MODULE_PARM_DESC(w4_sdca_trace,
+		 "Log regmap_write / sdw_write / fw nwrite to TAS2783");
+
+static bool w4_readback_trace = true;
+module_param(w4_readback_trace, bool, 0644);
+MODULE_PARM_DESC(w4_readback_trace,
+		 "Read back PDE23/PPU21/FU mute/AMP after key milestones");
 #define FW_DL_OFFSET	84 /* binary file information */
 #define FW_FL_HDR	20 /* minimum number of bytes in one chunk */
 #define TAS2783_FW_NWRITE_RETRIES	5
@@ -107,6 +124,81 @@
 static s32 tas_io_init(struct device *dev, struct sdw_slave *slave);
 static s32 tas2783_fw_reinit(struct device *dev, struct sdw_slave *slave);
 
+static atomic_t w4_seq = ATOMIC_INIT(0);
+
+static u8 tas2783_w4_uid(struct tas2783_prv *tas_dev)
+{
+	return tas_dev->sdw_peripheral ?
+	       tas_dev->sdw_peripheral->id.unique_id : 0;
+}
+
+static void tas2783_w4_life(struct device *dev, u8 uid,
+			    const char *fn, const char *phase)
+{
+	if (!w4_lifecycle_trace)
+		return;
+	dev_info(dev, "W4 ctx=life seq=%d uid=%d fn=%s phase=%s\n",
+		 atomic_inc_return(&w4_seq), uid, fn, phase);
+}
+
+static s32 tas2783_w4_regmap_write(struct tas2783_prv *tas_dev, u32 reg, u32 val)
+{
+	s32 ret = regmap_write(tas_dev->regmap, reg, val);
+
+	if (w4_sdca_trace)
+		dev_info(tas_dev->dev,
+			 "W4 ctx=sdca fn=regmap_write uid=%d reg=0x%08x val=0x%x ret=%d\n",
+			 tas2783_w4_uid(tas_dev), reg, val, ret);
+	return ret;
+}
+
+static s32 tas2783_w4_sdw_write(struct tas2783_prv *tas_dev, u32 addr, u8 val)
+{
+	s32 ret;
+
+	if (!tas_dev->sdw_peripheral)
+		return -ENODEV;
+	ret = sdw_write_no_pm(tas_dev->sdw_peripheral, addr, val);
+	if (w4_sdca_trace)
+		dev_info(tas_dev->dev,
+			 "W4 ctx=sdca fn=sdw_write uid=%d addr=0x%08x val=0x%x ret=%d\n",
+			 tas2783_w4_uid(tas_dev), addr, val, ret);
+	return ret;
+}
+
+static void tas2783_w4_readback(struct device *dev, struct tas2783_prv *tas_dev,
+				const char *tag)
+{
+	unsigned int pde, ppu, fu21, fu23, amp;
+	s32 r_pde, r_ppu, r_fu21, r_fu23, r_amp;
+
+	if (!w4_readback_trace)
+		return;
+
+	r_pde = regmap_read(tas_dev->regmap,
+			    SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_PDE23,
+					 TAS2783_SDCA_CTL_REQ_POW_STATE, 0),
+			    &pde);
+	r_ppu = regmap_read(tas_dev->regmap,
+			    SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_PPU21, 0x10, 0),
+			    &ppu);
+	r_fu21 = regmap_read(tas_dev->regmap,
+			     SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_FU21,
+					  TAS2783_SDCA_CTL_FU_MUTE, 1),
+			     &fu21);
+	r_fu23 = regmap_read(tas_dev->regmap,
+			     SDW_SDCA_CTL(1, TAS2783_SDCA_ENT_FU23,
+					  TAS2783_SDCA_CTL_FU_MUTE, 1),
+			     &fu23);
+	r_amp = regmap_read(tas_dev->regmap, TAS2783_AMP_LEVEL, &amp);
+
+	dev_info(dev,
+		 "W4 ctx=rb tag=%s uid=%d PDE23=%u/%d PPU21=%u/%d FU21m=%u/%d FU23m=%u/%d AMP=%u/%d init=%d fw_ok=%d done=%d\n",
+		 tag, tas2783_w4_uid(tas_dev),
+		 pde, r_pde, ppu, r_ppu, fu21, r_fu21, fu23, r_fu23, amp, r_amp,
+		 tas_dev->hw_init, tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
+}
+
 static const struct reg_default tas2783_reg_default[] = {
 	{TAS2783_AMP_LEVEL, 0x28},
 	{TASDEV_REG_SDW(0, 0, 0x03), 0x28},
@@ -654,6 +746,8 @@
 
 static s32 tas2783_update_calibdata(struct tas2783_prv *tas_dev)
 {
+	tas2783_w4_life(tas_dev->dev, tas2783_w4_uid(tas_dev),
+			"update_calib", "enter");
 	efi_guid_t efi_guid = TAS2783_CALI_GUID;
 	u32 attr, i, *tmp_val;
 	unsigned long size;
@@ -703,6 +797,9 @@
 		tas2783_set_calib_params_to_device(tas_dev, tmp_val);
 	mutex_unlock(&tas_dev->calib_lock);
 
+	tas2783_w4_life(tas_dev->dev, tas2783_w4_uid(tas_dev),
+			"update_calib", ret ? "exit_err" : "exit_ok");
+
 	return ret;
 }
 
