diff --git a/sound/soc/codecs/tas2783-sdw.c b/sound/soc/codecs/tas2783-sdw.c
--- a/sound/soc/codecs/tas2783-sdw.c
+++ b/sound/soc/codecs/tas2783-sdw.c
@@ -734,6 +734,11 @@
 	struct tas2783_prv *tas_dev =
 		(struct tas2783_prv *)context;
 	const u8 *buf = NULL;
+	u8 uid = tas_dev->sdw_peripheral ?
+		 tas_dev->sdw_peripheral->id.unique_id : 0;
+
+	dev_info(tas_dev->dev, "TAS2783Q2 fn=fw_ready enter uid=0x%x fmw=%p\n",
+		 uid, fmw);
 	s32  img_sz, ret = 0, cur_file = 0;
 	s32 offset = 0;
 
@@ -797,6 +802,9 @@
 		if (ret < 0) {
 			dev_err(tas_dev->dev,
 				"FW download failed: %d", ret);
+			dev_info(tas_dev->dev,
+				 "TAS2783Q2 fn=fw_ready nwrite_fail uid=0x%x file_idx=%d rc=%d\n",
+				 uid, cur_file, ret);
 			break;
 		}
 		cur_file++;
@@ -814,6 +822,10 @@
 	if (!ret)
 		tas_dev->fw_dl_success = true;
 	tas_dev->fw_dl_task_done = true;
+	dev_info(tas_dev->dev,
+		 "TAS2783Q2 fn=fw_ready exit uid=0x%x ret=%d cur_file=%d fmw_ok=%d success=%d done=%d\n",
+		 uid, ret, cur_file, fmw && fmw->data ? 1 : 0,
+		 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 	wake_up(&tas_dev->fw_wait);
 	if (fmw)
 		release_firmware(fmw);
@@ -922,6 +934,9 @@
 
 	if (!tas_dev->fw_dl_success && !tas_dev->fw_dl_task_done &&
 	    tas_dev->status == SDW_SLAVE_ATTACHED) {
+		dev_info(tas_dev->dev,
+			 "TAS2783Q2 fn=hw_params reinit uid=0x%x hw_init=%d\n",
+			 sdw_peripheral->id.unique_id, tas_dev->hw_init);
 		ret = tas2783_fw_reinit(&sdw_peripheral->dev, sdw_peripheral);
 		if (ret)
 			dev_warn(tas_dev->dev,
@@ -929,10 +944,18 @@
 	}
 
 	if (!tas_dev->fw_dl_success && !tas_dev->fw_dl_task_done) {
+		dev_info(tas_dev->dev,
+			 "TAS2783Q2 fn=hw_params wait uid=0x%x success=%d done=%d\n",
+			 sdw_peripheral->id.unique_id,
+			 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 		ret = wait_event_timeout(tas_dev->fw_wait, tas_dev->fw_dl_task_done,
 					 msecs_to_jiffies(TIMEOUT_FW_DL_MS));
 		if (!ret)
 			dev_err(tas_dev->dev, "fw download wait timeout in hw_params");
+		dev_info(tas_dev->dev,
+			 "TAS2783Q2 fn=hw_params wait_done uid=0x%x waited=%d success=%d done=%d\n",
+			 sdw_peripheral->id.unique_id, ret,
+			 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 	}
 
 	if (!tas_dev->fw_dl_success) {
@@ -1144,6 +1167,10 @@
 		tas_dev->hw_init = false;
 		tas_dev->fw_dl_task_done = false;
 		tas_dev->fw_dl_success = false;
+		dev_info(dev,
+			 "TAS2783Q2 fn=system_suspend invalidate uid=0x%x\n",
+			 tas_dev->sdw_peripheral ?
+			 tas_dev->sdw_peripheral->id.unique_id : 0);
 	}
 
 	return tas2783_sdca_dev_suspend(dev);
@@ -1173,8 +1200,18 @@
 	regcache_cache_only(tas_dev->regmap, false);
 	regcache_sync(tas_dev->regmap);
 
-	if (tas_dev->status == SDW_SLAVE_ATTACHED && !tas_dev->hw_init)
+	if (tas_dev->status == SDW_SLAVE_ATTACHED && !tas_dev->hw_init) {
+		dev_info(dev,
+			 "TAS2783Q2 fn=system_resume reinit uid=0x%x status=%d hw_init=%d success=%d done=%d\n",
+			 slave->id.unique_id, tas_dev->status, tas_dev->hw_init,
+			 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 		ret = tas2783_fw_reinit(dev, slave);
+	} else {
+		dev_info(dev,
+			 "TAS2783Q2 fn=system_resume skip_reinit uid=0x%x status=%d hw_init=%d success=%d done=%d\n",
+			 slave->id.unique_id, tas_dev->status, tas_dev->hw_init,
+			 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
+	}
 	return ret;
 }
 
@@ -1214,6 +1251,11 @@
 	s32 ret;
 	u8 unique_id = tas_dev->sdw_peripheral->id.unique_id;
 
+	dev_info(dev,
+		 "TAS2783Q2 fn=io_init enter uid=0x%x hw_init=%d success=%d done=%d\n",
+		 unique_id, tas_dev->hw_init, tas_dev->fw_dl_success,
+		 tas_dev->fw_dl_task_done);
+
 	if (tas_dev->hw_init)
 		return 0;
 
@@ -1240,12 +1282,18 @@
 		return ret;
 	}
 
+	dev_info(dev, "TAS2783Q2 fn=io_init nowait uid=0x%x ret=%d bin=%s\n",
+		 unique_id, ret, tas_dev->rca_binaryname);
+
 	ret = wait_event_timeout(tas_dev->fw_wait, tas_dev->fw_dl_task_done,
 				 msecs_to_jiffies(TIMEOUT_FW_DL_MS));
 	if (!ret) {
 		dev_err(tas_dev->dev, "fw request, wait_event timeout\n");
 		ret = -EAGAIN;
 	} else {
+		dev_info(dev,
+			 "TAS2783Q2 fn=io_init wait uid=0x%x waited=%d success=%d done=%d\n",
+			 unique_id, ret, tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 		if (tas_dev->sa_func_data)
 			ret = sdca_regmap_write_init(dev, tas_dev->regmap,
 						     tas_dev->sa_func_data);
@@ -1260,6 +1308,9 @@
 			tas_dev->hw_init = true;
 	}
 
+	dev_info(dev,
+		 "TAS2783Q2 fn=io_init exit uid=0x%x ret=%d hw_init=%d success=%d done=%d\n",
+		 unique_id, ret, tas_dev->hw_init, tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
 	return ret;
 }
 
@@ -1267,6 +1318,9 @@
 {
 	struct tas2783_prv *tas_dev = dev_get_drvdata(dev);
 
+	dev_info(dev, "TAS2783Q2 fn=fw_reinit enter uid=0x%x\n",
+		 slave->id.unique_id);
+
 	tas_dev->hw_init = false;
 	tas_dev->fw_dl_task_done = false;
 	tas_dev->fw_dl_success = false;
@@ -1280,6 +1334,11 @@
 	struct tas2783_prv *tas_dev = dev_get_drvdata(&slave->dev);
 	struct device *dev = &slave->dev;
 
+	dev_info(dev,
+		 "TAS2783Q2 fn=update_status uid=0x%x status=%d hw_init=%d success=%d done=%d\n",
+		 slave->id.unique_id, status, tas_dev->hw_init,
+		 tas_dev->fw_dl_success, tas_dev->fw_dl_task_done);
+
 	dev_dbg(dev, "Peripheral status = %s",
 		status == SDW_SLAVE_UNATTACHED ? "unattached" :
 		 status == SDW_SLAVE_ATTACHED ? "attached" : "alert");
@@ -1295,14 +1354,20 @@
 	/* Perform initialization only if slave status
 	 * is present and hw_init flag is false
 	 */
-	if (tas_dev->hw_init || tas_dev->status != SDW_SLAVE_ATTACHED)
+	if (tas_dev->hw_init || tas_dev->status != SDW_SLAVE_ATTACHED) {
+		dev_info(dev,
+			 "TAS2783Q2 fn=update_status skip_io_init uid=0x%x hw_init=%d status=%d\n",
+			 slave->id.unique_id, tas_dev->hw_init, tas_dev->status);
 		return 0;
+	}
 
 	/* updated the cache data to device */
 	regcache_cache_only(tas_dev->regmap, false);
 	regcache_sync(tas_dev->regmap);
 
 	/* perform I/O transfers required for Slave initialization */
+	dev_info(dev, "TAS2783Q2 fn=update_status call_io_init uid=0x%x\n",
+		 slave->id.unique_id);
 	return tas_io_init(&slave->dev, slave);
 }
 
