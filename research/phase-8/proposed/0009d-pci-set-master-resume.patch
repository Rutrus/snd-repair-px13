From: snd-repair phase8 <snd-repair@local>
Subject: [PATCH phase8 0009d] Falsify: pci_set_master on system resume (patch D)

--- a/sound/soc/amd/ps/pci-ps.c
+++ b/sound/soc/amd/ps/pci-ps.c
@@ -790,6 +790,8 @@ static int snd_acp_resume(struct device *dev)
 	pr_info("PHASE7 ctx=acp fn=pm_resume_enter resume=%u irq=%d msi=%d\n",
 		snd_repair_phase7_acp_resume_id(), pci->irq,
 		pci_dev_msi_enabled(pci) ? 1 : 0);
+	pci_set_master(pci);
+	pr_info("PHASE9 ctx=acp fn=falsify patch=D\n");
 	ret = acp_hw_resume(dev);
 	snd_repair_phase7_pm_resume_trace(dev, adata, ret);
 	return ret;
